generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Courier {
  id        String          @id @default(uuid())
  name      String
  phone     String          @unique
  password  String
  createdAt DateTime        @default(now())
  orders    DeliveryOrder[]
  contacts  Contact[]
}

model Contact {
  id          String      @id @default(uuid())
  courierId   String
  courier     Courier     @relation(fields: [courierId], references: [id], onDelete: Cascade)
  phone       String
  displayName String
  remark      String?
  createdAt   DateTime    @default(now())
  households  Household[]

  @@index([courierId])
  @@index([phone])
}

model Household {
  id          String          @id @default(uuid())
  contact     Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId   String
  addressText String
  lat         Float
  lng         Float
  doorplate   String?
  note        String?
  createdAt   DateTime        @default(now())
  orders      DeliveryOrder[]
}

model DeliveryOrder {
  id          String        @id @default(uuid())
  courier     Courier       @relation(fields: [courierId], references: [id], onDelete: Cascade)
  courierId   String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId String
  status      OrderStatus   @default(pending)
  gasQuantity Int?
  plannedTime DateTime?
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?
  notes       DeliveryNote[]

  @@index([courierId])
  @@index([status])
  @@index([createdAt])
}

model DeliveryNote {
  id        String         @id @default(uuid())
  order     DeliveryOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  content   String
  createdAt DateTime       @default(now())
}

enum OrderStatus {
  pending
  delivering
  done
  canceled
}
